<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/nativePlayerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:keepScreenOn="true"
        android:visibility="gone"
        app:resize_mode="zoom"
        app:show_buffering="never"
        app:surface_type="surface_view"
        app:use_controller="false" />

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <FrameLayout
        android:id="@+id/nativeWatchOverlayRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false">

        <FrameLayout
            android:id="@+id/nativeLoadingContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/nativeLoadingBrandImage"
                android:layout_width="236dp"
                android:layout_height="82dp"
                android:layout_gravity="start|top"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/app_brand"
                android:scaleType="fitStart" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/nativeLoadingChannelLogo"
                    android:layout_width="220dp"
                    android:layout_height="140dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/nativeLoadingFallbackName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/nativeLoadingProgress"
                    style="@style/Widget.MaterialComponents.LinearProgressIndicator"
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:minHeight="4dp"
                    app:indicatorColor="@android:color/white"
                    app:trackColor="#40FFFFFF"
                    app:trackCornerRadius="2dp"
                    app:trackThickness="4dp" />

                <TextView
                    android:id="@+id/nativeLoadingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Loading..."
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/nativeLoadingSubtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:maxWidth="260dp"
                    android:textColor="#CCFFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nativeLoadingMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:maxWidth="280dp"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/nativeWatchPanel"
            android:layout_width="336dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="24dp"
            android:background="#D9111111"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/nativeWatchTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/nativeWatchMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/nativeWatchEpgList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false" />

            <LinearLayout
                android:id="@+id/nativeWatchActionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/nativeOpenChannelsButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:backgroundTint="#18FFFFFF"
                    android:minHeight="40dp"
                    android:text="Channels"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/nativeOpenJioButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#1EFFFFFF"
                    android:minHeight="40dp"
                    android:text="Jio"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nativeWatchAudioSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/nativeWatchAudioLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audio"
                    android:textAllCaps="true"
                    android:textColor="#A6FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/nativeWatchAudioList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nativeWatchControlsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/nativePreviousButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#1FFFFFFF"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:minHeight="44dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="8dp"
                    android:text="Previous"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/nativeFullscreenButton"
                    android:layout_width="52dp"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="8dp"
                    android:backgroundTint="#24FFFFFF"
                    android:minHeight="44dp"
                    android:text="[]"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/nativeNextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#1FFFFFFF"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="2"
                    android:minHeight="44dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="8dp"
                    android:text="Next"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/nativeWatchHints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="◀ ▶ Channel  •  OK Menu  •  0-9 Tune  •  F Full"
                android:textColor="#82FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nativeChannelBrowserPanel"
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="372dp"
            android:layout_marginBottom="24dp"
            android:background="#E1111111"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/nativeChannelBrowserTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Channels"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/nativeCloseChannelBrowserButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:backgroundTint="#18FFFFFF"
                    android:minHeight="36dp"
                    android:text="Close"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/nativeChannelBrowserMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Browse and switch channels natively"
                android:textColor="#99FFFFFF"
                android:textSize="10sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/nativeChannelBrowserList"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nativeJioPanel"
            android:layout_width="420dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="#F0111111"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="18dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/nativeJioTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jio Settings"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/nativeCloseJioButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:backgroundTint="#18FFFFFF"
                    android:minHeight="36dp"
                    android:text="Close"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/nativeJioStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/nativeJioMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#99FFFFFF"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/nativeJioOtpModeButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:backgroundTint="#18FFFFFF"
                    android:minHeight="38dp"
                    android:text="OTP"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/nativeJioImportModeButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#18FFFFFF"
                    android:minHeight="38dp"
                    android:text="Import"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/nativeJioSearchModeButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#18FFFFFF"
                    android:minHeight="38dp"
                    android:text="Search"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nativeJioOtpSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/nativeJioPhoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#16FFFFFF"
                    android:hint="Jio phone number"
                    android:imeOptions="actionNext"
                    android:inputType="phone"
                    android:minHeight="48dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#77FFFFFF" />

                <EditText
                    android:id="@+id/nativeJioOtpInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#16FFFFFF"
                    android:hint="OTP"
                    android:inputType="number"
                    android:minHeight="48dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#77FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/nativeJioSendOtpButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:backgroundTint="#18FFFFFF"
                        android:minHeight="40dp"
                        android:text="Send OTP"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/nativeJioVerifyOtpButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#22FFFFFF"
                        android:minHeight="40dp"
                        android:text="Verify OTP"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nativeJioImportSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/nativeJioImportPhoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#16FFFFFF"
                    android:hint="Jio phone number (optional)"
                    android:inputType="phone"
                    android:minHeight="48dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#77FFFFFF" />

                <EditText
                    android:id="@+id/nativeJioImportPayloadInput"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="8dp"
                    android:background="#16FFFFFF"
                    android:gravity="top|start"
                    android:hint="Paste session JSON"
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#77FFFFFF" />

                <Button
                    android:id="@+id/nativeJioImportButton"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#22FFFFFF"
                    android:minHeight="40dp"
                    android:text="Import Session"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nativeJioSearchSection"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="14dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/nativeJioSearchInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#16FFFFFF"
                        android:hint="Search Jio channels"
                        android:imeOptions="actionSearch"
                        android:minHeight="44dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#77FFFFFF" />

                    <Button
                        android:id="@+id/nativeJioRefreshButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#18FFFFFF"
                        android:minHeight="40dp"
                        android:text="Refresh"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/nativeJioCatalogSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#99FFFFFF"
                    android:textSize="10sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/nativeJioCatalogList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

    </FrameLayout>

</FrameLayout>
